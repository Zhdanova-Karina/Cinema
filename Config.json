{
  "cinema": {                       // Кинотеатр
    "name": "Космос",               // Название кинотеатра
    "address": "ул. Ленина, 1",     // Адрес
    "workingHours": "10:00-23:00"   // Часы работы
  },

  "halls": [                        // Массив залов кинотеатра
    {
      "type": "ImaxHall",           // Тип зала
      "number": 1,                  // Номер зала
      "capacity": 250,              // Количество мест
      "equipment": [                // Массив оборудования в зале
        {
          "type": "ImaxProjector",  // Тип проектора
          "id": "proj_imax_101",    // id устройства
          "lampHours": 150,         // Наработка лампы проектора в часах
          "calibrationRequired": true // Флаг необходимости калибровки
        },
        {
          "type": "SurroundSound", // Тип звука
          "id": "sound_101",       // id устройства
          "maxVolume": 100         // Максимальная громкость
        },
        {
          "type": "LightSystem",  // Тип освещения
          "id": "light_101",      // id устройства
          "defaultDim": 15        // Уровень яркости по умолчанию в процентах (целое число от 0 до 100)
        },
        {
          "type": "AirConditioner", // Тип кондиционера
          "id": "ac_101",           // id устройства
          "minTemp": 20,            // Минимальная температура
          "maxTemp": 24             // Максимальная температура
        },
        {
          "type": "DoorLock",       // Тип дверного замка
          "id": "door_101",         // id замка
          "autoLockDelay": 30       // Задержка автоматической блокировки в секундах
        }
      ]
    },
    {
      "type": "VipHall",            // Тип зала вип
      "number": 2,
      "capacity": 50,
      "equipment": [                // Массив оборудования
        {
          "type": "Projector",
          "id": "proj_201",
          "lampHours": 320
        },
        {
          "type": "SoundSystem",
          "id": "sound_201"
        },
        {
          "type": "LightSystem",
          "id": "light_201",
          "defaultDim": 30
        },
        {
          "type": "AirConditioner",
          "id": "ac_201",
          "minTemp": 22,
          "maxTemp": 23
        },
        {
          "type": "DoorLock",
          "id": "door_201"
        }
      ]
    },
    {
      "type": "StandardHall",         //Стандартный тип зала
      "number": 3,
      "capacity": 120,
      "equipment": [                  // Массив оборудования
        {
          "type": "Projector",
          "id": "proj_301",
          "lampHours": 450
        },
        {
          "type": "StandardSound",
          "id": "sound_301"
        },
        {
          "type": "LightSystem",
          "id": "light_301",
          "defaultDim": 25
        },
        {
          "type": "AirConditioner",
          "id": "ac_301",
          "minTemp": 20,
          "maxTemp": 25
        },
        {
          "type": "DoorLock",
          "id": "door_301"
        }
      ]
    }
  ],

  "scenarios": {                      // Объект с настраиваемыми сценариями автоматизации
    "sessionStart": [                 // Массив команд для сценария "Начало сеанса"
      {                             // Первая команда
        "delay": 0,                 // Задержка перед выполнением 0 секунд (выполняется сразу)
        "command": "LightSystem.dim(20)" // Команда: приглушить свет до 20%
      },
      {                             // Вторая команда
        "delay": 10,                // Задержка 10 секунд после предыдущей команды
        "command": "Projector.playMovie" // Команда: запустить проектор (начать показ фильма)
      },
      {                             // Третья команда
        "delay": 2,                 // Задержка 2 секунды после запуска проектора
        "command": "SoundSystem.setVolume(70)" // Команда: установить громкость звука 70%
      }
    ],
    "sessionEnd": [                 // Массив команд для сценария "Окончание сеанса"
      {                             // Первая команда
        "delay": 0,                 // Выполняется сразу
        "command": "Projector.stop" // Команда: остановить проектор
      },
      {                             // Вторая команда
        "delay": 1,                 // Через 1 секунду после остановки проектора
        "command": "LightSystem.on()" // Команда: включить свет (полная яркость)
      },
      {                             // Третья команда
        "delay": 5,                 // Через 5 секунд после включения света
        "command": "DoorLock.unlock()" // Команда: открыть двери для выхода зрителей
      }
    ],
    "emergencyStop": [              // Массив команд для сценария "Аварийная остановка"
      {                             // Первая команда
        "delay": 0,                 // Выполняется мгновенно
        "command": "Projector.stop" // Немедленно остановить проектор
      },
      {                             // Вторая команда
        "delay": 0,                 // Выполняется одновременно с первой
        "command": "SoundSystem.mute" // Отключить звук (без задержки)
      },
      {                             // Третья команда
        "delay": 1,                 // Через 1 секунду после остановки
        "command": "LightSystem.on()" // Включить свет
      },
      {                             // Четвертая команда
        "delay": 2,                 // Через 2 секунды после включения света
        "command": "SoundSystem.setVolume(0)" // Дополнительно установить громкость на 0
      },
      {                             // Пятая команда
        "delay": 2,                 // Через 2 секунды (параллельно с предыдущей)
        "command": "DoorLock.unlock()" // Открыть двери для эвакуации
      }
    ]
  },

  "timings": {                      // Объект с временными параметрами работы кинотеатра
    "preparationDuration": 20,      // Время на подготовку зала к сеансу в минутах
    "cleanupDuration": 15,          // Время на уборку зала после сеанса в минутах
    "breakDuration": 10             // Длительность технического перерыва между сеансами в минутах
  }
}